{
  "$description": "Cannabis Canary(c) design tokens. Colors mirror colors.css; contrast ratios are computed WCAG 2.x values against the noted background. Canary 300-600 are graphic-only (fail text contrast on white).",
  "color": {
    "white":     { "value": "#FFFFFF" },
    "gray": {
      "050": { "value": "#F5F7FA", "use": "subtle background" },
      "100": { "value": "#E4E7EB", "use": "dividers, disabled fills" },
      "200": { "value": "#CBD2D9", "use": "default borders (decorative)" },
      "400": { "value": "#7B8794", "use": "input outlines / strong borders", "contrastOnWhite": 3.66, "meets": "3:1 UI component" },
      "600": { "value": "#616E7C", "use": "muted text", "contrastOnWhite": 5.21, "meets": "AA" },
      "700": { "value": "#3E4C59", "use": "secondary text", "contrastOnWhite": 8.81, "meets": "AA, AAA" }
    },
    "ink":       { "value": "#1F2933", "use": "primary text", "contrastOnWhite": 14.76, "meets": "AA, AAA" },
    "canary": {
      "100": { "value": "#FFF8E1", "use": "yellow tint surface (ink on it: 13.89:1)" },
      "300": { "value": "#FADB5F", "use": "GRAPHIC ONLY — never text" },
      "400": { "value": "#F7C948", "use": "GRAPHIC ONLY — app-icon field (ink on it: 9.42:1)" },
      "500": { "value": "#F0B429", "use": "GRAPHIC ONLY — mark body" },
      "600": { "value": "#DE911D", "use": "GRAPHIC ONLY — mark wing accent" },
      "700": { "value": "#7B5C00", "use": "yellow-family text/icons on white", "contrastOnWhite": 6.23, "meets": "AA" }
    },
    "blue": {
      "050": { "value": "#EBF6FB", "use": "info surface (blue-700 on it: 6.03:1)" },
      "700": { "value": "#0F609B", "use": "links, primary actions", "contrastOnWhite": 6.63, "meets": "AA", "whiteTextOnIt": 6.63 }
    },
    "warn": {
      "050": { "value": "#FDF6E3", "use": "warning surface (warn-800 on it: 8.28:1)" },
      "800": { "value": "#723B13", "use": "warning text", "contrastOnWhite": 8.93, "meets": "AA, AAA" }
    },
    "green": {
      "700": { "value": "#147D64", "use": "success text/icons", "contrastOnWhite": 5.06, "meets": "AA" }
    }
  },
  "typography": {
    "$rationale": "The app renders inside Epic's embedded Hyperdrive browser (Chromium webview, most often on Windows) and inside Cerner. System fonts avoid webfont downloads, match host-OS rendering, and are the safe choice in a locked-down EHR webview.",
    "fontFamily": {
      "base": { "value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif" },
      "mono": { "value": "ui-monospace, 'Cascadia Mono', 'Segoe UI Mono', Consolas, Menlo, monospace", "use": "codes, identifiers, raw values" }
    },
    "fontSize": {
      "xs":  { "value": "12px", "use": "footnotes, citations — use sparingly; small text needs 7:1-class colors (ink/gray-700)" },
      "sm":  { "value": "13px", "use": "helper text, table meta" },
      "md":  { "value": "14px", "use": "body default inside EHR chrome" },
      "lg":  { "value": "16px", "use": "form inputs, emphasized body" },
      "xl":  { "value": "18px", "use": "section headings" },
      "2xl": { "value": "22px", "use": "page/card titles" },
      "3xl": { "value": "28px", "use": "computed dose display (mg/day)" }
    },
    "fontWeight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600, "use": "headings, buttons, the computed dose" }
    },
    "lineHeight": {
      "tight":  { "value": 1.25, "use": "headings" },
      "normal": { "value": 1.5,  "use": "body" }
    },
    "numerals": {
      "value": "font-variant-numeric: tabular-nums",
      "use": "all dosage figures, potency percentages, and longitudinal chart axes — digits must align and not reflow"
    }
  },
  "spacing": {
    "$rationale": "4px base scale. Dense-but-breathable: the form lives in a constrained EHR panel.",
    "1": { "value": "4px" },
    "2": { "value": "8px" },
    "3": { "value": "12px" },
    "4": { "value": "16px" },
    "5": { "value": "24px" },
    "6": { "value": "32px" },
    "7": { "value": "48px" }
  },
  "radius": {
    "sm": { "value": "4px", "use": "inputs, buttons" },
    "md": { "value": "6px", "use": "cards, callouts" }
  },
  "focus": {
    "ring": { "value": "2px solid #0F609B", "offset": "2px", "use": "keyboard focus — never remove" }
  }
}
